# Local development runtime database.
DATABASE_URL="file:./prisma/dev.db"

# Prisma CLI always uses a local SQLite file for migrate / generate workflows.
LOCAL_DATABASE_URL="file:./prisma/dev.db"

# Optional local override for pnpm dev. Omit to default to the daily database target.
COIN_HUB_DEV_DATABASE_TARGET=""

# Canonical Turso runtime database variables. Vercel should set these directly.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# Local-only Turso sources for pnpm dev:daily / pnpm dev:prod.
# Put real values in .env.local rather than committing them here.
TURSO_DAILY_DATABASE_URL=""
TURSO_DAILY_AUTH_TOKEN=""
TURSO_PRODUCTION_DATABASE_URL=""
TURSO_PRODUCTION_AUTH_TOKEN=""

# Required for the single-user auth flow and signed session cookies.
APP_PASSWORD="change-me"

# Public app metadata shown in the UI and local links.
NEXT_PUBLIC_APP_NAME=Coin Hub
NEXT_PUBLIC_SITE_URL=http://localhost:3000
