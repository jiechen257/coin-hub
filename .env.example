# Prisma CLI, runtime, and the readiness endpoint all point at the same local SQLite file.
DATABASE_URL="file:./prisma/dev.db"

# Required for the single-user auth flow and signed session cookies.
APP_PASSWORD="change-me"

# Public app metadata shown in the UI and local links.
NEXT_PUBLIC_APP_NAME=Coin Hub
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Binance USDⓈ-M 合约 K 线基础地址，默认走官方 REST 域名。
BINANCE_FUTURES_BASE_URL=https://fapi.binance.com

# Binance 官方历史归档地址，历史回填脚本默认从这里下载 monthly / daily K 线 zip。
BINANCE_PUBLIC_DATA_BASE_URL=https://data.binance.vision

# 后台独立行情同步循环的默认轮询间隔，单位毫秒。
MARKET_DATA_SYNC_INTERVAL_MS=60000
