# Prisma CLI, runtime, and the readiness endpoint all point at the same local SQLite file.
DATABASE_URL="file:./prisma/dev.db"

# Required for the single-user auth flow and signed session cookies.
APP_PASSWORD="change-me"

# Public app metadata shown in the UI and local links.
NEXT_PUBLIC_APP_NAME=Coin Hub
NEXT_PUBLIC_SITE_URL=http://localhost:3000
