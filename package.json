{
  "name": "coin-hub",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "db:prepare": "node ./scripts/prepare-local-db.mjs && prisma generate && prisma migrate deploy",
    "db:seed:research-mocks": "pnpm db:prepare && tsx ./scripts/seed-research-desk-mocks.ts",
    "dev": "pnpm db:prepare && tsx ./scripts/dev.ts",
    "dev:daily": "pnpm db:prepare && tsx ./scripts/dev.ts --target=daily",
    "dev:prod": "pnpm db:prepare && tsx ./scripts/dev.ts --target=production",
    "dev:local": "pnpm db:prepare && tsx ./scripts/dev.ts --target=local",
    "build": "next build",
    "postinstall": "prisma generate",
    "start": "pnpm db:prepare && next start",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.6.0",
